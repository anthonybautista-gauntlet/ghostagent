{
  "name": "ghostagent-monorepo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anthonybautista-gauntlet/ghostagent.git"
  },
  "homepage": "https://github.com/anthonybautista-gauntlet/ghostagent#readme",
  "bugs": {
    "url": "https://github.com/anthonybautista-gauntlet/ghostagent/issues"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build:core": "npm run build -w @ghost_agent/core",
    "build:ui": "npm run build -w @ghost_agent/ui",
    "build:evals": "npm run build -w @ghost_agent/evals",
    "build": "npm run build:core && npm run build:ui && npm run build:evals",
    "pack:core": "npm pack -w @ghost_agent/core",
    "pack:ui": "npm pack -w @ghost_agent/ui",
    "pack:evals": "npm pack -w @ghost_agent/evals",
    "verify:pack": "node ./scripts/verify-pack.mjs"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
